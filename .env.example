# Required on Koyeb/Vercel for HubCloud and Cloudflare-protected download pages.
# Deploy the worker in ../cf-worker/ (wrangler deploy), then paste the workers.dev URL here.
CF_WORKER_URL=https://http-proxy.YOUR_SUBDOMAIN.workers.dev

# Optional: FlareSolverr instance (fallback if CF worker cannot solve a challenge)
# FLARESOLVERR_ENDPOINT=http://your-flaresolverr:8191

# Optional: TMDB fallback when Cinemeta has no metadata
# TMDB_KEY=

# Koyeb sets PORT automatically
PORT=3000
